<HeadLayout />

{{outlet}}

{{#each this.message.toasts as |toast|}}
  <Toast @toast={{toast}} />
{{/each}}

<footer>
  <audio
    preload="none"
    {{on-insert this.audio.onAudioElementInsert}}
    {{on "canplay" this.audio.onCanPlay}}
    {{on "durationchange" this.audio.onDurationChange}}
    {{on "ended" this.audio.onEnded}}
    {{on "error" this.audio.onError}}
    {{on "pause" this.audio.onPause}}
    {{on "playing" this.audio.onPlaying}}
    {{on "ratechange" this.audio.onRateChange}}
    {{on "seeked" this.audio.onSeeked}}
    {{on "seeking" this.audio.onSeeking}}
    {{on "timeupdate" this.audio.onTimeUpdate}}
    {{on "volumechange" this.audio.onVolumeChange}}
    {{on "waiting" this.audio.onWaiting}}
  ></audio>
  {{#if this.audio.episode}}
    <PlayerBar @episode={{this.audio.episode}} />
  {{/if}}
</footer>
